# Alchemy RPC endpoint for Polygon Amoy testnet
# Get your API key at https://alchemy.com
API_URL=https://polygon-amoy.g.alchemy.com/v2/YOUR_ALCHEMY_API_KEY

# Private key of the deployer account (without 0x prefix)
# For local dev, use one of the keys printed by `npx hardhat node`
# For testnet, use an account funded with Amoy MATIC from https://faucet.polygon.technology/
METAMASK_PRIVATE_KEY=your_private_key_without_0x_prefix
